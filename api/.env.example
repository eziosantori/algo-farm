ANTHROPIC_API_KEY=your-key-here
GEMINI_API_KEY=your-key-here        # Google AI Studio (free tier)
GEMINI_MODEL=gemini-2.0-flash-lite  # override model (default: gemini-2.0-flash-lite)
OPENROUTER_API_KEY=your-key-here    # openrouter.ai (free Qwen models)
OPENROUTER_MODEL=openrouter/free    # fallback/default model if UI does not pass model
PORT=3001
DB_PATH=./algo_farm.db

# Phase 3 — BullMQ worker
REDIS_URL=redis://localhost:6379   # start Redis: docker compose up -d redis
PYTHON_BIN=python                  # path to Python interpreter (default: python)
DATA_DIR=./engine/data             # root dir for OHLCV Parquet files
ENGINE_DB_PATH=./engine_runs.db    # SQLite for Python engine internal job tracking
WORKER_CONCURRENCY=2               # number of concurrent backtest jobs
